@model IEnumerable<BrewTime.Application.DTOs.ProductoDTO>

<h1>Productos</h1>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Nombre</th>
            <th>Categoría</th>
            <th>Descripción</th>
            <th>Precio</th>
            <th>Estado</th>
            <th>Fecha de Creación</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ProductoID</td>
                <td>@item.Nombre</td>
                <td>@item.CategoriaNombre</td>
                <td>@item.Descripcion</td>
                <td>@item.Precio.ToString("C", new System.Globalization.CultureInfo("es-CR"))</td>
                <td>
                    @if (item.Activo)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </td>
                <td>@item.FechaCreacion.ToString("dd/MM/yyyy")</td>
                <td>
                    <a asp-action="Detail" asp-route-id="@item.ProductoID"
                       class="btn btn-sm btn-primary">
                        Ver detalle
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>