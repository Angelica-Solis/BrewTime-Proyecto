@model IEnumerable<BrewTime.Application.DTOs.ProductoDTO>

@section Styles {
    <link rel="stylesheet" href="~/css/producto.css" asp-append-version="true" />
}

@{
    ViewData["Title"] = "Productos";
}

<div class="brew-page">

    @* Hero banner *@
    <div class="brew-hero">
        <div class="brew-hero-inner">
            <p class="brew-hero-eyebrow">Brew Time · Cafetería</p>
            <h1 class="brew-titulo">Nuestros <em>Productos</em></h1>
            <p class="brew-subtitulo">Cada sorbo, cada sabor, cada experiencia.</p>
            <div class="brew-hero-line">
                <span></span>
                <i>Menú &amp; precios</i>
                <span></span>
            </div>
            @* Botón de mantenimiento - se ocultará según rol *@
            <div class="brew-hero-actions">
                <a asp-action="Maintenance" class="brew-btn-admin">
                    Administrar productos
                </a>
            </div>
        </div>
    </div>

    @* Contenido *@
    <div class="brew-content">

        @if (!Model.Any())
        {
            <div class="brew-grid">
                <div class="brew-empty">
                    <span class="brew-empty-icon">☕</span>
                    <p>No hay productos registrados aún.</p>
                </div>
            </div>
        }
        else
        {
            <p class="brew-count">@Model.Count() producto(s) registrado(s)</p>

            <div class="brew-grid">
                @foreach (var item in Model)
                {
                    <div class="brew-card">

                        @* Franja decorativa superior *@
                        <div class="brew-card-stripe"></div>

                        <div class="brew-card-body">

                            @* Chip de categoría *@
                            <span class="brew-card-chip">@item.CategoriaNombre</span>

                            @* Nombre del producto *@
                            <p class="brew-card-producto">@item.Nombre</p>

                            @* Descripción *@
                            <p class="brew-card-desc">@item.Descripcion</p>

                            @* Footer: precio + estado + botón *@
                            <div class="brew-card-footer">
                                <div class="brew-card-footer-left">
                                    <span class="brew-badge-tiempo">
                                         @item.Precio.ToString("C", new System.Globalization.CultureInfo("es-CR"))
                                    </span>
                                    @if (item.Activo)
                                    {
                                        <span class="brew-badge-activo">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="brew-badge-inactivo">Inactivo</span>
                                    }
                                </div>
                                <a asp-action="Detail"
                                   asp-route-id="@item.ProductoID"
                                   class="brew-btn-detalle">
                                    Ver detalle
                                </a>
                            </div>

                        </div>
                    </div>
                }
            </div>
        }

    </div>
</div>
