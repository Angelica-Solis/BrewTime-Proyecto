@model IEnumerable<BrewTime.Application.DTOs.ProductoDTO>
@{
    var inactivos = ViewBag.Inactivos as IEnumerable<BrewTime.Application.DTOs.ProductoDTO>
                   ?? Enumerable.Empty<BrewTime.Application.DTOs.ProductoDTO>();
    ViewData["Title"] = "Mantenimiento de Productos";
}

@section Styles {
    <link rel="stylesheet" href="~/css/producto.css" asp-append-version="true" />
}

<div class="brew-page">
  
    <div class="brew-hero">
        <div class="brew-hero-inner">
            <p class="brew-hero-eyebrow">Brew Time · Administración</p>
            <h1 class="brew-titulo">Mantenimiento de <em>Productos</em></h1>
            <p class="brew-subtitulo">Creá, editá, activá o desactivá productos del catálogo.</p>
            <div class="brew-hero-line">
                <span></span><i>Gestión de catálogo</i><span></span>
            </div>
        </div>
    </div>

    <div class="brew-content">

        <div class="brew-maint-toolbar">
            <a asp-action="Index" class="brew-btn-volver">← Volver al catálogo</a>
            <a asp-action="Create" class="brew-btn-nuevo">+ Nuevo producto</a>
        </div>

        @* ── PRODUCTOS ACTIVOS ── *@
        <h2 class="brew-section-title">
            <span class="brew-section-dot activo"></span>
            Productos activos
            <span class="brew-section-count">@Model.Count()</span>
        </h2>

        @if (!Model.Any())
        {
            <div class="brew-empty"><span class="brew-empty-icon">☕</span><p>No hay productos activos.</p></div>
        }
        else
        {
            <div class="brew-maint-table-wrap">
                <table class="brew-maint-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Nombre</th>
                            <th>Categoría</th>
                            <th>Precio</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ProductoID</td>
                                <td>@item.Nombre</td>
                                <td><span class="brew-card-chip">@item.CategoriaNombre</span></td>
                                <td>@item.Precio.ToString("C", new System.Globalization.CultureInfo("es-CR"))</td>
                                <td class="brew-maint-actions">
                                    <a asp-action="Edit" asp-route-id="@item.ProductoID"
                                       class="brew-btn-editar">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                    <form asp-action="ToggleActivo" method="post" style="display:inline">
                                        <input type="hidden" name="id" value="@item.ProductoID" />
                                        <button type="button" class="brew-btn-desactivar btn-toggle-activo" data-nombre="@item.Nombre" data-accion="desactivar">
                                            <i class="bi bi-toggle-on"></i> Desactivar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @* ── PRODUCTOS INACTIVOS ── *@
        <h2 class="brew-section-title" style="margin-top:2.5rem;">
            <span class="brew-section-dot inactivo"></span>
            Productos inactivos
            <span class="brew-section-count">@inactivos.Count()</span>
        </h2>

        @if (!inactivos.Any())
        {
            <div class="brew-empty"><span class="brew-empty-icon">✓</span><p>No hay productos inactivos.</p></div>
        }
        else
        {
            <div class="brew-maint-table-wrap brew-table-inactiva">
                <table class="brew-maint-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Nombre</th>
                            <th>Categoría</th>
                            <th>Precio</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in inactivos)
                        {
                            <tr class="brew-row-inactiva">
                                <td>@item.ProductoID</td>
                                <td>@item.Nombre</td>
                                <td><span class="brew-card-chip">@item.CategoriaNombre</span></td>
                                <td>@item.Precio.ToString("C", new System.Globalization.CultureInfo("es-CR"))</td>
                                <td class="brew-maint-actions">
                                    <form asp-action="ToggleActivo" method="post" style="display:inline">
                                        <input type="hidden" name="id" value="@item.ProductoID" />
                                        <button type="button" class="brew-btn-activar btn-toggle-activo" data-nombre="@item.Nombre" data-accion="activar">
                                            <i class="bi bi-toggle-off"></i> Activar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.querySelectorAll('.btn-toggle-activo').forEach(button => {
            button.addEventListener('click', function(e) {
                e.preventDefault();
                const form = this.closest('form');
                const nombre = this.getAttribute('data-nombre');
                const accion = this.getAttribute('data-accion');
                const esDesactivar = accion === 'desactivar';

                Swal.fire({
                    title: esDesactivar ? '¿Desactivar producto?' : '¿Activar producto?',
                    text: esDesactivar 
                        ? `El producto "${nombre}" ya no estará visible en el menú.`
                        : `El producto "${nombre}" volverá a estar visible en el menú.`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: esDesactivar ? '#8a2020' : '#243318',
                    cancelButtonColor: '#5a3e28',
                    confirmButtonText: esDesactivar ? 'Sí, desactivar' : 'Sí, activar',
                    cancelButtonText: 'Cancelar',
                    background: '#f0e2cc',
                    color: '#2e1e0e'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });
    </script>
}