@model BrewTime.Application.DTOs.ProductoDetalleDTO

<div class="container mt-4">

    <a asp-action="Index" class="btn btn-secondary mb-3">← Volver al listado</a>

    <h1>@Model.Nombre</h1>
    <hr />

    <div class="row">

        <!-- Imagen -->
        <div class="col-md-4">
            @if (!string.IsNullOrEmpty(Model.ImagenPrincipal))
            {
                <img src="@Model.ImagenPrincipal"
                     alt="@Model.Nombre"
                     class="img-fluid rounded shadow" />
            }
            else
            {
                <div class="bg-light border rounded d-flex align-items-center
                            justify-content-center"
                     style="height:250px;">
                    <span class="text-muted">Sin imagen disponible</span>
                </div>
            }
        </div>

        <!-- Información -->
        <div class="col-md-8">

            <dl class="row">

                <dt class="col-sm-3">Categoría</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-info text-dark">@Model.CategoriaNombre</span>
                </dd>

                <dt class="col-sm-3">Descripción</dt>
                <dd class="col-sm-9">@Model.Descripcion</dd>

                <dt class="col-sm-3">Precio</dt>
                <dd class="col-sm-9">
                    <strong>
                        @Model.Precio.ToString("C", new System.Globalization.CultureInfo("es-CR"))
                    </strong>
                </dd>

                <dt class="col-sm-3">Estado</dt>
                <dd class="col-sm-9">
                    @if (Model.Activo)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </dd>

                <dt class="col-sm-3">Fecha de creación</dt>
                <dd class="col-sm-9">@Model.FechaCreacion.ToString("dd/MM/yyyy")</dd>

                <dt class="col-sm-3">Ingredientes</dt>
                <dd class="col-sm-9">
                    @if (Model.Ingredientes.Any())
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var ingrediente in Model.Ingredientes)
                            {
                                <li>• @ingrediente</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <span class="text-muted">No registrados</span>
                    }
                </dd>

            </dl>

        </div>
    </div>
</div>