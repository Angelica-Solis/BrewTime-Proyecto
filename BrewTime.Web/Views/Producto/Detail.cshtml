@model BrewTime.Application.DTOs.ProductoDetalleDTO

@section Styles {
    <link rel="stylesheet" href="~/css/producto.css" asp-append-version="true" />
}

@{
    ViewData["Title"] = Model.Nombre;
}

<div class="brew-page">

    @* Hero banner *@
    <div class="brew-hero">
        <div class="brew-hero-inner">
            <p class="brew-hero-eyebrow">Brew Time · Cafetería</p>
            <h1 class="brew-titulo">Detalle del <em>Producto</em></h1>
            <p class="brew-subtitulo">Todo lo que necesitas saber sobre esta preparación.</p>
            <div class="brew-hero-line">
                <span></span>
                <i>Ingredientes &amp; precio</i>
                <span></span>
            </div>
        </div>
    </div>

    @* Contenido *@
    <div class="brew-content">

        <a asp-action="Index" class="brew-btn-volver">← Volver al listado</a>

        <div class="brew-detail-card">

            @* Imagen *@
            <div class="brew-detail-img-wrap">
                @if (Model.Imagenes.Any())
                {
                    <div id="carouselProducto"
                         class="carousel slide carousel-fade brew-detail-carousel"
                         data-bs-ride="carousel">

                        @if (Model.Imagenes.Count > 1)
                        {
                            <div class="carousel-indicators">
                                @for (int i = 0; i < Model.Imagenes.Count; i++)
                                {
                                    <button type="button"
                                            data-bs-target="#carouselProducto"
                                            data-bs-slide-to="@i"
                                            class="@(i == 0 ? "active" : "")"
                                            aria-current="@(i == 0 ? "true" : "false")"
                                            aria-label="Slide @(i + 1)"></button>
                                }
                            </div>
                        }

                        <div class="carousel-inner">

                            @for (int i = 0; i < Model.Imagenes.Count; i++)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : "")">

                                    <img src="@Model.Imagenes[i]"
                                         class="d-block w-100 brew-detail-img"
                                         alt="@Model.Nombre" />

                                </div>
                            }

                        </div>

                        @if (Model.Imagenes.Count > 1)
                        {
                            <button class="carousel-control-prev"
                                    type="button"
                                    data-bs-target="#carouselProducto"
                                    data-bs-slide="prev">

                                <span class="carousel-control-prev-icon"></span>

                            </button>

                            <button class="carousel-control-next"
                                    type="button"
                                    data-bs-target="#carouselProducto"
                                    data-bs-slide="next">

                                <span class="carousel-control-next-icon"></span>

                            </button>
                        }

                    </div>
                }
                else
                {
                    <div class="brew-detail-img-placeholder">
                        <span>☕</span>
                        <p>Sin imagen disponible</p>
                    </div>
                }
            </div>

            @* Info *@
            <div class="brew-detail-info">

                <h2 class="brew-detail-nombre">@Model.Nombre</h2>

                @* Categoría *@
                <span class="brew-card-chip mb-3">@Model.CategoriaNombre</span>

                @* Descripción *@
                <p class="brew-detail-desc">@Model.Descripcion</p>

                @* Datos en fila *@
                <div class="brew-detail-meta">

                    <div class="brew-meta-item">
                        <span class="brew-meta-label">Precio</span>
                        <span class="brew-badge-tiempo">
                            @Model.Precio.ToString("C", new System.Globalization.CultureInfo("es-CR"))
                        </span>
                    </div>

                    <div class="brew-meta-item">
                        <span class="brew-meta-label">Estado</span>
                        @if (Model.Activo)
                        {
                            <span class="brew-badge-activo">Activo</span>
                        }
                        else
                        {
                            <span class="brew-badge-inactivo">Inactivo</span>
                        }
                    </div>

                    <div class="brew-meta-item">
                        <span class="brew-meta-label">Fecha de creación</span>
                        <span class="brew-meta-valor">@Model.FechaCreacion.ToString("dd/MM/yyyy")</span>
                    </div>

                </div>

                @* Ingredientes *@
                <div class="brew-detail-ingredientes">
                    <p class="brew-meta-label">Ingredientes</p>
                    @if (Model.Ingredientes.Any())
                    {
                        <ul class="brew-ingredientes-list">
                            @foreach (var ingrediente in Model.Ingredientes)
                            {
                                <li class="brew-ingrediente-item">
                                    <span class="brew-ingrediente-dot">•</span>
                                    @ingrediente
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="brew-detail-empty">No hay ingredientes registrados.</p>
                    }
                </div>

            </div>
        </div>
    </div>
</div>
