@model IEnumerable<BrewTime.Application.DTOs.UsuarioDTO>
@section Styles {
    <link rel="stylesheet" href="~/css/usuario.css" asp-append-version="true" />
}
@{
    ViewData["Title"] = "Listado de Usuarios";
}
<div class="brew-page">
    <section class="brew-hero">
        <div class="brew-hero-inner">
            <p class="brew-hero-eyebrow">Administración</p>
            <h1 class="brew-titulo">
                Listado de <em>Usuarios - María Angélica Solís Sibaja</em>
            </h1>
            <p class="brew-subtitulo">
                Consulta y administración de los usuarios registrados en el sistema.
            </p>
            <div class="brew-hero-line">
                <span></span>
                <i>BrewTime</i>
                <span></span>
            </div>
        </div>
    </section>
    <div class="brew-content">
        <div class="brew-count">
            Total de usuarios: @Model.Count()
        </div>
        @if (Model.Any())
        {
            <div class="brew-table-wrapper">
                <div class="brew-table-stripe"></div>
                <table class="brew-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Rol</th>
                            <th>Estado</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var usuario in Model)
                        {
                            <tr>
                                <td class="brew-td-nombre">
                                    @usuario.Nombre @usuario.Apellidos
                                </td>
                                <td>
                                    <span class="brew-card-chip">
                                        @usuario.NombreRol
                                    </span>
                                </td>
                                <td>
                                    @if (usuario.Activo)
                                    {
                                        <span class="brew-badge-estado activo">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="brew-badge-estado inactivo">
                                            Inactivo
                                        </span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Detail"
                                       asp-route-id="@usuario.UsuarioId"
                                       class="brew-btn-detalle">
                                        Ver detalle
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="brew-empty">
                No hay usuarios registrados.
            </div>
        }
    </div>
</div>