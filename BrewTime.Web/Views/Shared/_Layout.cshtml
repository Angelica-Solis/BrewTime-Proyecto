<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BrewTime</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    @RenderSection("Styles", required: false)
    <link rel="stylesheet" href="~/BrewTime.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chatbot.css" asp-append-version="true" />
</head>
<body class="brew-body">
    <header>
        <nav class="brew-navbar navbar navbar-expand-sm navbar-toggleable-sm">
            <div class="container-fluid">

                <!-- Brand con logo -->
                <a class="brew-brand navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" alt="BrewTime Logo" class="brew-logo-img" />
                    BrewTime
                </a>

                <!-- Toggler mobile -->
                <button class="brew-toggler navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Links -->
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="brew-nav-link nav-link" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>

                        <li class="nav-item">
                            <a class="brew-nav-link nav-link" asp-area="" asp-controller="ProcesoPreparacion" asp-action="Index">Procesos</a>
                        </li>
                        <li class="nav-item">
                            <a class="brew-nav-link nav-link" asp-area="" asp-controller="Producto" asp-action="Index">Productos</a>
                        </li>
                        <li class="nav-item">
                            <a class="brew-nav-link nav-link" asp-area="" asp-controller="Combo" asp-action="Index">Combos</a>
                        </li>
                        
                        <li class="nav-item">
                            <a class="brew-nav-link nav-link" asp-area="" asp-controller="Menu" asp-action="Maintenance">Menús</a>
                        </li>
                        <li class="nav-item">
                            <a class="brew-nav-link nav-link" asp-area="" asp-controller="Menu" asp-action="Disponible"> Menú Disponible </a>
                        </li>
                        <li class="nav-item">
                            <a class="brew-nav-link nav-link" asp-area="" asp-controller="Usuario" asp-action="Index"> Usuarios </a>
                        </li>
                       
                    </ul>
                </div>

            </div>
        </nav>
    </header>

    @* Sin container wrappe, cada vista maneja su propio fondo *@
    <main role="main" class="brew-main">
        @RenderBody()
    </main>

    <footer class="brew-footer">
        <div class="brew-footer-glow"></div>

        <div class="container brew-footer-main">

            <!-- Columna 1: Marca -->
            <div class="brew-footer-col brew-footer-brand-col">
                <span class="brew-footer-brand">☕ BrewTime</span>
                <p class="brew-footer-tagline">Café de especialidad y bubble tea, preparado con cariño todos los días.</p>
                <div class="brew-footer-social">
                    <a href="https://wa.me/50688888888" target="_blank" rel="noopener" class="brew-social-link" aria-label="WhatsApp">
                        <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.91C21.96 6.45 17.5 2 12.04 2zm5.8 14.15c-.24.68-1.4 1.3-1.93 1.38-.5.08-1.13.11-1.82-.11-.42-.13-.96-.31-1.65-.6-2.9-1.25-4.79-4.17-4.94-4.36-.14-.19-1.18-1.57-1.18-3 0-1.42.75-2.12 1.02-2.41.27-.29.58-.36.78-.36.19 0 .39 0 .56.01.18.01.42-.07.65.5.24.58.82 2 .89 2.15.07.14.12.31.02.5-.1.19-.15.31-.29.48-.15.17-.31.38-.44.51-.15.15-.3.31-.13.6.17.29.76 1.25 1.63 2.02 1.12 1 2.06 1.31 2.35 1.46.29.15.46.13.63-.05.17-.19.72-.84.91-1.13.19-.29.38-.24.63-.14.26.1 1.63.77 1.91.91.29.14.48.21.55.33.07.12.07.68-.16 1.36z" /></svg>
                    </a>
                    <a href="https://facebook.com/brewtime" target="_blank" rel="noopener" class="brew-social-link" aria-label="Facebook">
                        <svg viewBox="0 0 24 24"><path fill="currentColor" d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.44 2.91h-2.34V22c4.78-.79 8.44-4.94 8.44-9.94z" /></svg>
                    </a>
                    <a href="https://instagram.com/brewtime" target="_blank" rel="noopener" class="brew-social-link" aria-label="Instagram">
                        <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 2.2c3.2 0 3.58.01 4.85.07 1.17.05 1.97.24 2.43.4a4.9 4.9 0 0 1 1.77 1.15 4.9 4.9 0 0 1 1.15 1.77c.16.46.35 1.26.4 2.43.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.24 1.97-.4 2.43a4.9 4.9 0 0 1-1.15 1.77 4.9 4.9 0 0 1-1.77 1.15c-.46.16-1.26.35-2.43.4-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.97-.24-2.43-.4a4.9 4.9 0 0 1-1.77-1.15 4.9 4.9 0 0 1-1.15-1.77c-.16-.46-.35-1.26-.4-2.43C2.21 15.58 2.2 15.2 2.2 12s.01-3.58.07-4.85c.05-1.17.24-1.97.4-2.43a4.9 4.9 0 0 1 1.15-1.77A4.9 4.9 0 0 1 5.59 1.8c.46-.16 1.26-.35 2.43-.4C9.29 1.34 9.67 1.33 12 1.33m0 2c-3.15 0-3.5.01-4.74.07-.98.04-1.5.2-1.85.34-.47.18-.8.4-1.15.75-.35.35-.57.68-.75 1.15-.14.36-.3.87-.34 1.85C3.11 8.4 3.1 8.75 3.1 11.9s.01 3.5.07 4.74c.04.98.2 1.5.34 1.85.18.47.4.8.75 1.15.35.35.68.57 1.15.75.36.14.87.3 1.85.34 1.24.06 1.59.07 4.74.07s3.5-.01 4.74-.07c.98-.04 1.5-.2 1.85-.34.47-.18.8-.4 1.15-.75.35-.35.57-.68.75-1.15.14-.36.3-.87.34-1.85.06-1.24.07-1.59.07-4.74s-.01-3.5-.07-4.74c-.04-.98-.2-1.5-.34-1.85a3 3 0 0 0-.75-1.15 3 3 0 0 0-1.15-.75c-.36-.14-.87-.3-1.85-.34C15.5 3.21 15.15 3.2 12 3.2zm0 3.5a5.3 5.3 0 1 1 0 10.6 5.3 5.3 0 0 1 0-10.6zm0 2a3.3 3.3 0 1 0 0 6.6 3.3 3.3 0 0 0 0-6.6zm5.5-2.1a1.24 1.24 0 1 1-2.48 0 1.24 1.24 0 0 1 2.48 0z" /></svg>
                    </a>
                </div>
            </div>

            <!-- Columna 2: Contacto -->
            <div class="brew-footer-col">
                <h6 class="brew-footer-heading">Contacto</h6>
                <ul class="brew-footer-list">
                    <li>
                        <span class="brew-footer-icon-wrap">
                            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5z" /></svg>
                        </span>
                        BrewTimeCR@hotmail.com
                    </li>
                    <li>
                        <span class="brew-footer-icon-wrap">
                            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24 11.36 11.36 0 0 0 3.57.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.36 11.36 0 0 0 .57 3.57 1 1 0 0 1-.25 1.02z" /></svg>
                        </span>
                        +506 8888-8888
                    </li>
                    <li>
                        <span class="brew-footer-icon-wrap">
                            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5z" /></svg>
                        </span>
                        San José, Costa Rica
                    </li>
                </ul>
            </div>

            <!-- Columna 3: Horario -->
            <div class="brew-footer-col">
                <h6 class="brew-footer-heading">Horario</h6>
                <ul class="brew-footer-list">
                    <li>Lun – Vie: 7:00am – 8:00pm</li>
                    <li>Sáb: 8:00am – 6:00pm</li>
                    <li>Dom: 9:00am – 3:00pm</li>
                </ul>
            </div>
        </div>

        <div class="brew-footer-divider">
            <span class="brew-footer-bean">●</span>
        </div>

        <div class="container brew-footer-bottom">
            <span class="brew-footer-copy">&copy; 2026 BrewTime — Café y Bubble</span>
            <span class="brew-footer-creators">Hecho con <span class="brew-heart">♥</span> por <strong>Angélica Solís Sibaja</strong> &amp; <strong>Erin Huang Lin</strong> &amp; <strong>Fabián Zamora Méndez</strong></span>
            <a class="brew-footer-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>


   


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/chatbot.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>