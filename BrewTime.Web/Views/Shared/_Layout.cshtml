<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BrewTime</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    @RenderSection("Styles", required: false)
    <link rel="stylesheet" href="~/BrewTime.Web.styles.css" asp-append-version="true" />
</head>
<body class="brew-body">
    <header>
        <nav class="brew-navbar navbar navbar-expand-sm navbar-toggleable-sm">
            <div class="container-fluid">

                <!-- Brand con logo -->
                <a class="brew-brand navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" alt="BrewTime Logo" class="brew-logo-img" />
                    BrewTime
                </a>

                <!-- Toggler mobile -->
                <button class="brew-toggler navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Links -->
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="brew-nav-link nav-link" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="brew-nav-link nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="brew-nav-link nav-link" asp-area="" asp-controller="ProcesoPreparacion" asp-action="Index">Procesos</a>
                        </li>
                        <li class="nav-item">
                            <a class="brew-nav-link nav-link" asp-area="" asp-controller="Producto" asp-action="Index">Productos</a>
                        </li>
                        <li class="nav-item">
                            <a class="brew-nav-link nav-link" asp-area="" asp-controller="Combo" asp-action="Index">Combos</a>
                        </li>
                        
                        <li class="nav-item">
                            <a class="brew-nav-link nav-link" asp-area="" asp-controller="Menu" asp-action="Index">Menús</a>
                        </li>
                        <li class="nav-item">
                            <a class="brew-nav-link nav-link" asp-area="" asp-controller="Menu" asp-action="Disponible"> Menú Disponible </a>
                        </li>
                        <li class="nav-item">
                            <a class="brew-nav-link nav-link" asp-area="" asp-controller="Usuario" asp-action="Index"> Usuarios </a>
                        </li>
                       
                    </ul>
                </div>

            </div>
        </nav>
    </header>

    @* Sin container wrappe, cada vista maneja su propio fondo *@
    <main role="main" class="brew-main">
        @RenderBody()
    </main>

    <footer class="brew-footer">
        <div class="container">
            <span class="brew-footer-copy">&copy; 2026 BrewTime — Café y Bubble</span>
            <a class="brew-footer-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>