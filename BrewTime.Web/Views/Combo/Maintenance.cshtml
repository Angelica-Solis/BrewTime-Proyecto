@model IEnumerable<BrewTime.Application.DTOs.ComboDTO>
@{
    var inactivos = ViewBag.Inactivos as IEnumerable<BrewTime.Application.DTOs.ComboDTO>
                   ?? Enumerable.Empty<BrewTime.Application.DTOs.ComboDTO>();
    ViewData["Title"] = "Mantenimiento de Combos";
}

@section Styles {
    <link rel="stylesheet" href="~/css/producto.css" asp-append-version="true" />
}

<div class="brew-page">

    <div class="brew-hero">
        <div class="brew-hero-inner">
            <p class="brew-hero-eyebrow">Brew Time · Administración</p>
            <h1 class="brew-titulo">Mantenimiento de <em>Combos</em></h1>
            <p class="brew-subtitulo">Activá o desactivá combos del catálogo.</p>
            <div class="brew-hero-line">
                <span></span><i>Gestión de combos</i><span></span>
            </div>
        </div>
    </div>

    <div class="brew-content">

        @* Toolbar *@
        <div class="brew-maint-toolbar">
            <a asp-action="Index" class="brew-btn-volver">← Volver al listado</a>
            <a asp-action="Create" class="brew-btn-nuevo">+ Nuevo combo</a>
        </div>

        @* ── COMBOS ACTIVOS ── *@
        <h2 class="brew-section-title">
            <span class="brew-section-dot activo"></span>
            Combos activos
            <span class="brew-section-count">@Model.Count()</span>
        </h2>

        @if (!Model.Any())
        {
            <div class="brew-empty"><span class="brew-empty-icon">☕</span><p>No hay combos activos.</p></div>
        }
        else
        {
            <div class="brew-maint-table-wrap">
                <table class="brew-maint-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Categoría</th>
                            <th>Precio especial</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Nombre</td>
                                <td><span class="brew-card-chip">@item.CategoriaNombre</span></td>
                                <td>@item.PrecioEspecial.ToString("C", new System.Globalization.CultureInfo("es-CR"))</td>
                                <td class="brew-maint-actions">
                                    <a asp-action="Edit" asp-route-id="@item.ComboID" class="brew-btn-editar">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                    <a asp-action="Detail" asp-route-id="@item.ComboID" class="brew-btn-editar">
                                        <i class="bi bi-eye"></i> Ver detalle
                                    </a>
                                    <form asp-action="ToggleActivo" method="post" style="display:inline"
                                          onsubmit="return confirm('¿Desactivar el combo «@item.Nombre»?')">
                                        <input type="hidden" name="id" value="@item.ComboID" />
                                        <button type="submit" class="brew-btn-desactivar">
                                            <i class="bi bi-toggle-on"></i> Desactivar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @* ── COMBOS INACTIVOS ── *@
        <h2 class="brew-section-title" style="margin-top:2.5rem;">
            <span class="brew-section-dot inactivo"></span>
            Combos inactivos
            <span class="brew-section-count">@inactivos.Count()</span>
        </h2>

        @if (!inactivos.Any())
        {
            <div class="brew-empty"><span class="brew-empty-icon">✓</span><p>No hay combos inactivos.</p></div>
        }
        else
        {
            <div class="brew-maint-table-wrap brew-table-inactiva">
                <table class="brew-maint-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Categoría</th>
                            <th>Precio especial</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in inactivos)
                        {
                            <tr class="brew-row-inactiva">
                                <td>@item.Nombre</td>
                                <td><span class="brew-card-chip">@item.CategoriaNombre</span></td>
                                <td>@item.PrecioEspecial.ToString("C", new System.Globalization.CultureInfo("es-CR"))</td>
                                @* Botones en fila de activos *@
                                <td class="brew-maint-actions">
                                    <a asp-action="Edit" asp-route-id="@item.ComboID" class="brew-btn-editar">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                    <a asp-action="Detail" asp-route-id="@item.ComboID" class="brew-btn-editar">
                                        <i class="bi bi-eye"></i> Ver detalle
                                    </a>
                                    <form asp-action="ToggleActivo" method="post" style="display:inline"
                                          onsubmit="return confirm('¿Activar el combo «@item.Nombre»?')">
                                        <input type="hidden" name="id" value="@item.ComboID" />
                                        <button type="submit" class="brew-btn-activar">
                                            <i class="bi bi-toggle-off"></i> Activar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>