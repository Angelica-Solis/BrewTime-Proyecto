@model BrewTime.Application.DTOs.ComboDetalleDTO

@section Styles {
    <link rel="stylesheet" href="~/css/combo.css" asp-append-version="true" />
}

@{
    ViewData["Title"] = Model.Nombre;
}

<div class="brew-page">
    @* Chatbot  *@
    <partial name="_Chatbot" />
    @* Hero banner *@
    <div class="brew-hero">
        <div class="brew-hero-inner">
            <p class="brew-hero-eyebrow">Brew Time · Cafetería</p>
            <h1 class="brew-titulo">Detalle del <em>Combo</em></h1>
            <p class="brew-subtitulo">Todo lo que incluye esta combinación especial.</p>
            <div class="brew-hero-line">
                <span></span>
                <i>Productos &amp; precio especial</i>
                <span></span>
            </div>
        </div>
    </div>

    @* Contenido *@
    <div class="brew-content">

        <a asp-action="Index" class="brew-btn-volver">← Volver al listado</a>

        <div class="brew-detail-card">

            @* Panel izquierdo: info principal *@
            <div class="brew-detail-info">

                <h2 class="brew-detail-nombre">@Model.Nombre</h2>

                <span class="brew-card-chip">@Model.CategoriaNombre</span>

                <p class="brew-detail-desc">@Model.Descripcion</p>

                @* Meta: precio, estado, fecha *@
                <div class="brew-detail-meta">
                    <div class="brew-meta-item">
                        <span class="brew-meta-label">Precio especial</span>
                        <span class="brew-badge-tiempo">
                            @Model.PrecioEspecial.ToString("C", new System.Globalization.CultureInfo("es-CR"))
                        </span>
                    </div>
                    <div class="brew-meta-item">
                        <span class="brew-meta-label">Estado</span>
                        @if (Model.Activo)
                        {
                            <span class="brew-badge-activo">Activo</span>
                        }
                        else
                        {
                            <span class="brew-badge-inactivo">Inactivo</span>
                        }
                    </div>
                    <div class="brew-meta-item">
                        <span class="brew-meta-label">Fecha de creación</span>
                        <span class="brew-meta-valor">@Model.FechaCreacion.ToString("dd/MM/yyyy")</span>
                    </div>
                </div>

            </div>

            @* Panel derecho: productos del combo *@
            <div class="brew-detail-productos">

                <p class="brew-productos-titulo">Productos incluidos</p>

                @if (Model.Productos.Any())
                {
                    <div class="brew-productos-list">
                        @foreach (var p in Model.Productos)
                        {
                            <div class="brew-producto-item">
                                <span class="brew-producto-nombre">@p.NombreProducto</span>
                                <span class="brew-producto-cantidad">x@(p.Cantidad)</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="brew-detail-empty">Sin productos asignados.</p>
                }

            </div>

        </div>
    </div>
</div>
