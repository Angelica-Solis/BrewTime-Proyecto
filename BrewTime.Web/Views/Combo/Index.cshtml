@model IEnumerable<BrewTime.Application.DTOs.ComboDTO>

@section Styles {
    <link rel="stylesheet" href="~/css/combo.css" asp-append-version="true" />
}

@{
    ViewData["Title"] = "Combos";
}

<div class="brew-page">

    @* Hero banner *@
    <div class="brew-hero">
        <div class="brew-hero-inner">
            <p class="brew-hero-eyebrow">Brew Time · Cafetería</p>
            <h1 class="brew-titulo">Nuestros <em>Combos</em></h1>
            <p class="brew-subtitulo">La mejor combinación al mejor precio.</p>
            <div class="brew-hero-line">
                <span></span>
                <i>Ofertas &amp; precios especiales</i>
                <span></span>
            </div>
        </div>
    </div>

    @* Contenido *@
    <div class="brew-content">

        @if (!Model.Any())
        {
            <div class="brew-grid">
                <div class="brew-empty">
                    <span class="brew-empty-icon"></span>
                    <p>No hay combos registrados aún.</p>
                </div>
            </div>
        }
        else
        {
            <p class="brew-count">@Model.Count() combo(s) disponible(s)</p>

            <div class="brew-grid">
                @foreach (var item in Model)
                {
                    <div class="brew-card">
                        <div class="brew-card-stripe"></div>
                        <div class="brew-card-body">

                            @* Chip de categoría *@
                            <span class="brew-card-chip">@item.CategoriaNombre</span>

                            @* Nombre del combo *@
                            <p class="brew-card-producto">@item.Nombre</p>

                            @* Descripción *@
                            <p class="brew-card-desc">@item.Descripcion</p>

                            @* Footer *@
                            <div class="brew-card-footer">
                                <span class="brew-badge-tiempo">
                                    @item.PrecioEspecial.ToString("C", new System.Globalization.CultureInfo("es-CR"))
                                </span>
                                <a asp-action="Detail"
                                   asp-route-id="@item.ComboID"
                                   class="brew-btn-detalle">
                                    Ver detalle
                                </a>
                            </div>

                        </div>
                    </div>
                }
            </div>
        }

    </div>
</div>
