@model ICollection<ProcesoPreparacionListadoDTO>
@section Styles {
    <link rel="stylesheet" href="~/css/procesoPreparacion.css" asp-append-version="true" />
}
@{
    ViewData["Title"] = "Proceso de Preparación";
}

<div class="brew-page">
    <div class="brew-hero">
        <div class="brew-hero-inner">
            <p class="brew-hero-eyebrow">Brew Time · Cafetería</p>
            <h1 class="brew-titulo">Proceso de <em>Preparación</em></h1>
            <p class="brew-subtitulo">Cada paso, cada estación, cada minuto importa.</p>
            <div class="brew-hero-line">
                <span></span>
                <i>Estaciones &amp; tiempos</i>
                <span></span>
            </div>
        </div>
    </div>

    <div class="brew-content">
        @if (!Model.Any())
        {
            <div class="brew-grid">
                <div class="brew-empty">
                    <span class="brew-empty-icon">☕</span>
                    <p>No hay pasos registrados aún.</p>
                </div>
            </div>
        }
        else
        {
            <p class="brew-count">@Model.Count pasos registrado(s)</p>
            <div class="brew-grid">
                @foreach (var item in Model)
                {
                    <div class="brew-card">
                        <div class="brew-card-stripe"></div>
                        <div class="brew-card-body">
                            <span class="brew-card-chip">Producto</span>
                            <p class="brew-card-producto">@item.NombreProducto</p>
                            <p class="brew-card-paso">
                                <strong>@item.CantidadProcesos</strong> paso(s) de preparación
                            </p>
                            <div class="brew-card-footer">
                                <span class="brew-badge-tiempo">☕ Brew</span>
                                <a class="brew-btn-detalle"
                                   asp-action="Detail"
                                   asp-route-id="@item.ProductoId">
                                    Ver detalle
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>