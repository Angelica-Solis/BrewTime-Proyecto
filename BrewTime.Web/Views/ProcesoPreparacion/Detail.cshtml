@model ProcesoPreparacionDetalleDTO

@section Styles {
    <link rel="stylesheet" href="~/css/procesoPreparacion.css" asp-append-version="true" />
}

@{
    ViewData["Title"] = "Detalle del Proceso";
}

<div class="brew-page">

    @* Hero banner *@
    <div class="brew-hero">
        <div class="brew-hero-inner">
            <p class="brew-hero-eyebrow">Brew Time · Cafetería</p>
            <h1 class="brew-titulo">Detalle del <em>Proceso</em></h1>
            <p class="brew-subtitulo">Información completa de preparación</p>
            <div class="brew-hero-line">
            </div>
        </div>
    </div>
  

    @* Contenido *@
    <div class="brew-content">
        <a asp-action="Index" class="brew-btn-volver">
            ← Volver al listado
        </a>
        <div class="brew-detalle-wrapper">

            <div class="brew-card">
                <div class="brew-card-stripe"></div>
                <div class="brew-card-body">

                    <h2 class="brew-detalle-producto">
                        @Model.NombreProducto
                    </h2>

                    @foreach (var item in Model.Procesos)
                    {
                        <div class="brew-paso-card">

                            <div class="brew-paso-numero">
                                @item.Orden.ToString("00")
                            </div>

                            <div>
                                <span class="brew-paso-label">
                                    Estación
                                </span>

                                <div class="brew-paso-estacion">
                                    @item.Estacion.Nombre
                                </div>
                            </div>

                            <div>
                                <span class="brew-paso-label">
                                    Tiempo estimado
                                </span>

                                <span class="brew-detalle-tiempo">
                                    @item.TiempoEstimadoMin min
                                </span>
                            </div>

                        </div>
                    }

                </div>
            </div>

        </div>
    </div>
  
</div>