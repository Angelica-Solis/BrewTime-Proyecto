@model IEnumerable<BrewTime.Application.DTOs.ProcesoPreparacionListadoDTO>
@{
    ViewData["Title"] = "Mantenimiento de Procesos de Preparación";
}
@section Styles {
    <link rel="stylesheet" href="~/css/procesoPreparacion.css" asp-append-version="true" />
}

<div class="brew-page">
 
    <div class="brew-hero">
        <div class="brew-hero-inner">
            <p class="brew-hero-eyebrow">BREW TIME · ADMINISTRACIÓN</p>
            <h1 class="brew-titulo">Mantenimiento de <em>Procesos de Preparación</em></h1>
            <p class="brew-subtitulo">Creá, editá y consultá los procesos de preparación de cada producto.</p>
            <div class="brew-hero-line">
                <span></span>
                <i>Gestión de Procesos</i>
                <span></span>
            </div>
        </div>
    </div>

    <div class="brew-content">

        <div class="brew-mant-header">
            <a asp-action="Index" asp-controller="Home" class="brew-btn-volver-mant">
                ← Volver
            </a>
            <a asp-action="Create" class="brew-btn-nuevo">
                + Nuevo Proceso
            </a>
        </div>

        <div class="brew-mant-title-row">
            <span class="brew-mant-dot"></span>
            <h2 class="brew-mant-title">Procesos registrados</h2>
            <span class="brew-mant-count">@(Model?.Count() ?? 0)</span>
        </div>

        <div class="brew-table-container">
            <table class="brew-table">
                <thead>
                    <tr>
                        <th style="width:60px;">#</th>
                        <th>Producto</th>
                        <th class="text-center">Cantidad de Estaciones</th>
                        <th class="text-center" style="width:260px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int i = 1;
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@i</td>
                                <td>@item.NombreProducto</td>
                                <td class="text-center">
                                    <span class="brew-badge-cantidad">@item.CantidadProcesos</span>
                                </td>
                                <td>
                                    <div class="brew-actions-cell">
                                        <a asp-action="Detail"
                                           asp-route-id="@item.ProductoId"
                                           class="brew-btn-detalle-table">
                                            <i class="bi bi-eye"></i> Detalle
                                        </a>
                                        <a asp-action="Edit"
                                           asp-route-id="@item.ProductoId"
                                           class="brew-btn-editar-table">
                                            <i class="bi bi-pencil-square"></i> Editar
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                    else
                    {
                        <tr class="brew-empty-row">
                            <td colspan="4">
                                No hay procesos de preparación registrados.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    @if (TempData["Success"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Éxito',
                text: '@TempData["Success"]',
                confirmButtonText: 'Aceptar'
            });
        </script>
    }
    @if (TempData["Error"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: '@TempData["Error"]',
                confirmButtonText: 'Aceptar'
            });
        </script>
    }
}