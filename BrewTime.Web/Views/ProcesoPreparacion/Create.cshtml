@model BrewTime.Application.DTOs.ProcesoPreparacionFormDTO
@using BrewTime.Application.DTOs

@section Styles {
    <link rel="stylesheet" href="~/css/procesoPreparacion.css" asp-append-version="true" />
}

@{
    ViewData["Title"] = "Crear Proceso de Preparación";
   
}

<div class="brew-page">

    <div class="brew-hero">
        <div class="brew-hero-inner">
            <span class="brew-hero-eyebrow">Nuevo Proceso</span>

            <h1 class="brew-titulo">
                Crear Proceso de <em>Preparación</em>
            </h1>

            <p class="brew-subtitulo">
                Seleccione las estaciones que forman parte del proceso y establezca el orden y tiempo estimado.
            </p>

            <div class="brew-hero-line">
                <span></span>
                <i>Configuración del flujo</i>
                <span></span>
            </div>
        </div>
    </div>

    <div class="brew-content">

        <div class="brew-form-card">

            <form asp-action="Create" method="post" class="brew-form">

                <div asp-validation-summary="ModelOnly" class="brew-error"></div>

                <div class="brew-form-group">
                    <label class="brew-form-label">Producto</label>

                    <select asp-for="ProductoId"
                            asp-items="ViewBag.Productos"
                            class="brew-select"
                            id="productoSelect">

                        <option value="">-- Seleccione un producto --</option>

                    </select>

                    <span asp-validation-for="ProductoId"
                          class="brew-error"></span>
                </div>
                <div class="mb-3 text-end">

                    <button type="button"
                            class="brew-btn-volver"
                            id="btnLimpiar">

                        Limpiar selección

                    </button>

                </div>
                <hr class="brew-detalle-divider" />

                <h4 class="brew-subtitulo-section">
                    Estaciones del proceso
                </h4>

                <p class="brew-form-desc">
                    Seleccione las estaciones que forman parte del proceso y establezca el orden y tiempo estimado.
                </p>

                <div class="row brew-estaciones-grid">

                    @for (int index = 0; index < Model.Estaciones.Count; index++)
                    {
                        var esCaja = Model.Estaciones[index].Nombre == "Caja";
                        var esEmplatado = Model.Estaciones[index].Nombre == "Emplatado";
                        <div class="col-md-6 mb-3">

                            <div class="brew-estacion-card">

                                <input asp-for="Estaciones[index].EstacionId"
                                       type="hidden" />

                                <input asp-for="Estaciones[index].Nombre"
                                       type="hidden" />

                                <div class="form-check mb-2">

                                    <input asp-for="Estaciones[index].Seleccionada"
                                           class="form-check-input brew-checkbox"
                                           data-caja="@esCaja"
                                           data-emplatado="@esEmplatado" />

                                    <label class="form-check-label fw-bold">
                                        @Model.Estaciones[index].Nombre
                                    </label>

                                </div>

                                <div class="mb-2">

                                    <label class="brew-form-label">
                                        Orden
                                    </label>

                                    <input asp-for="Estaciones[index].Orden"
                                           class="form-control brew-input-number orden-input"
                                           min="1"
                                           readonly />

                                 

                                </div>

                                <div>

                                    <label class="brew-form-label">
                                        Tiempo estimado (min)
                                    </label>

                                    <input asp-for="Estaciones[index].TiempoEstimadoMin"
                                           class="form-control brew-input-number tiempo-input"
                                           min="1"
                                           readonly />

                                </div>

                            </div>

                        </div>
                    }

                </div>

                <div class="brew-form-actions">

                    <button type="submit"
                            class="brew-btn-detalle"
                            >
                        Guardar
                    </button>

                    <a asp-action="Maintenance"
                       class="brew-btn-volver">
                        Cancelar
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    @{
     

        var errores = ViewData.ModelState.Values
            .SelectMany(v => v.Errors)
            .Select(e => e.ErrorMessage)
            .ToList();


    }
    
     
    
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @* Mensaje de éxito *@
    @if (TempData["Success"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Éxito',
                text: '@TempData["Success"]',
                confirmButtonText: 'Aceptar'
            });
        </script>
    }

    @* Mensajes de error *@
    @if (errores.Any())
    {
        <script>

            let mensaje = "";

            @foreach (var error in errores)
            {
                <text>
                        mensaje += "• @error<br>";
                </text>
            }

                Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'error',
                title: 'No se pudo guardar',
                html: mensaje,
                showConfirmButton: false,
                timer: 3000
            });




        </script>
    }

    <script>

            document.addEventListener("DOMContentLoaded", function () {

            const producto = document.getElementById("productoSelect");

            function esComida() {

                return producto.selectedOptions[0].text.includes("Repostería")
                    || producto.selectedOptions[0].text.includes("Combo");

            }

            function actualizar(card) {

                const check = card.querySelector(".brew-checkbox");
                const orden = card.querySelector(".orden-input");
                const tiempo = card.querySelector(".tiempo-input");

                const esCaja = check.dataset.caja === "True";
                const esEmplatado = check.dataset.emplatado === "True";

                
               // Solo Caja y Emplatado tienen el orden bloqueado
                if (esCaja || esEmplatado) {
                    orden.readOnly = true;
                } else {
                    orden.readOnly = !check.checked;
                }

                // El tiempo solo se habilita si la estación está seleccionada
                tiempo.readOnly = !check.checked;

                if (esComida()) {

                    if (esCaja || esEmplatado) {

                        check.checked = true;
                        check.disabled = true;

                    } else {

                        check.disabled = false;

                    }

                } else {

                    check.disabled = false;

                }

                if (!check.checked) {

                    orden.value = "";
                    tiempo.value = "";

                }

            }

            document.querySelectorAll(".brew-estacion-card")
                .forEach(card => {

                    actualizar(card);

                    card.querySelector(".brew-checkbox")
                        .addEventListener("change", function () {
                            actualizar(card);
                        });

                });

            producto.addEventListener("change", function () {

                document.querySelectorAll(".brew-estacion-card")
                    .forEach(card => actualizar(card));

            });

        });

          // Botón limpiar
            document.getElementById("btnLimpiar")
                .addEventListener("click", function () {

                    document.querySelectorAll(".brew-estacion-card")
                        .forEach(card => {

                            const checkbox = card.querySelector(".brew-checkbox");
                            const orden = card.querySelector(".orden-input");
                            const tiempo = card.querySelector(".tiempo-input");

                            checkbox.checked = false;

                            orden.value = "";
                            tiempo.value = "";

                            orden.disabled = true;
                            tiempo.disabled = true;

                        });

                });

    </script>

}