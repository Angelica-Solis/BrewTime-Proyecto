@{
    ViewData["Title"] = "Inicio";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<div class="home-page">
    @* Chatbot  *@
    <partial name="_Chatbot" />
    @* Hero  *@
    <div class="home-hero">
        <div class="home-hero-inner">
            <p class="home-hero-eyebrow">Café y Bubble · Costa Rica</p>
            <h1 class="home-hero-titulo">
                Bienvenido a <br>
                <em>Brew Time</em>
            </h1>
            <p class="home-hero-subtitulo">
                Café de especialidad y bubble tea preparados con amor.<br />
                Cada sorbo, una experiencia.
            </p>
            <a href="/producto" class="home-hero-cta">Ver menú completo</a>
            <div class="home-hero-line">
                <span></span>
                <i>Bubble Tea &amp; Café</i>
                <span></span>
            </div>
        </div>
    </div>

    <div class="section-divider" style="margin-top:2.5rem;"><hr /></div>
    <div class="home-about">

        <div class="home-about-card">
            <span>NOSOTROS</span>

            <h2>Más que una bebida.</h2>

            <p>
                En Brew Time creemos que cada taza y cada bubble tea
                son una experiencia. Combinamos ingredientes de calidad,
                creatividad y un ambiente acogedor.
            </p>
        </div>

        <div class="home-about-card">
            <span>BREW TIME</span>

            <h2>¿Qué nos hace diferentes?</h2>

            <ul>
                <li>Café de especialidad.</li>
                <li>Bubble Tea artesanal.</li>
                <li>Postres únicos.</li>
                <li>Ingredientes frescos.</li>
                <li>Atención personalizada.</li>

            </ul>
        </div>

    </div>
    <div class="section-divider" style="margin-top:2.5rem;"><hr /></div>

    <div class="home-history">

        <div class="home-history-year">
            <span>DESDE</span>
            <h2>2025</h2>
        </div>

        <div class="home-history-info">

            <h3>Comenzamos a compartir momentos especiales.</h3>

            <p>
                Desde Costa Rica, Brew Time nació con la idea de unir
                el café de especialidad y el auténtico bubble tea en un
                solo lugar.
            </p>

            <div class="home-location">
                📍 San José, Costa Rica
            </div>

        </div>

    </div>
    <div class="section-divider" style="margin-top:2.5rem;"><hr /></div>
    @* Carrusel *@
    <div class="home-carrusel">
        <div class="home-carrusel-header">
            <div>
                <p class="home-menu-eyebrow">Lo más pedido</p>
                <h2 class="home-menu-titulo" style="margin-bottom:0;">Estrellas de la temporada</h2>
            </div>
            <div class="home-carrusel-nav">
                <button class="home-carrusel-btn" id="brew-prev" aria-label="Anterior">&#8592;</button>
                <button class="home-carrusel-btn" id="brew-next" aria-label="Siguiente">&#8594;</button>
            </div>
        </div>
        <div class="home-carrusel-viewport">
            <div class="home-carrusel-track" id="brew-track">
                <div class="home-carrusel-item">
                    <div class="home-card">
                        <div class="home-card-stripe"></div>
                        <div class="home-card-img-wrap">
                            <img src="~/images/productos/Bubble Tea Original_BubbleTea.png" alt="Bubble Tea Original" />
                        </div>
                        <div class="home-card-body">
                            <span class="home-card-cat">Bubble Tea</span>
                            <p class="home-card-nombre">Original Bubble Tea</p>
                            <p class="home-card-precio">₡2,500</p>
                        </div>
                    </div>
                </div>
                <div class="home-carrusel-item">
                    <div class="home-card">
                        <div class="home-card-stripe"></div>
                        <div class="home-card-img-wrap">
                            <img src="~/images/productos/CoffeeBoba _Bubble tea.png" alt="Coffee Boba" />
                        </div>
                        <div class="home-card-body">
                            <span class="home-card-cat">Bubble Tea</span>
                            <p class="home-card-nombre">Coffee Boba</p>
                            <p class="home-card-precio">₡3,000</p>
                        </div>
                    </div>
                </div>
                <div class="home-carrusel-item">
                    <div class="home-card">
                        <div class="home-card-stripe"></div>
                        <div class="home-card-img-wrap">
                            <img src="~/images/productos/IcedMocha_Café.png" alt="Iced Mocha" />
                        </div>
                        <div class="home-card-body">
                            <span class="home-card-cat">Café</span>
                            <p class="home-card-nombre">Iced Mocha</p>
                            <p class="home-card-precio">₡2,700</p>
                        </div>
                    </div>
                </div>
                <div class="home-carrusel-item">
                    <div class="home-card">
                        <div class="home-card-stripe"></div>
                        <div class="home-card-img-wrap">
                            <img src="~/images/productos/Bubble Tea Matcha_BubbleTea.png" alt="Matcha Bubble Tea" />
                        </div>
                        <div class="home-card-body">
                            <span class="home-card-cat">Bubble Tea</span>
                            <p class="home-card-nombre">Matcha Bubble Tea</p>
                            <p class="home-card-precio">₡2,800</p>
                        </div>
                    </div>
                </div>
                <div class="home-carrusel-item">
                    <div class="home-card">
                        <div class="home-card-stripe"></div>
                        <div class="home-card-img-wrap">
                            <img src="~/images/productos/OreoBoba_Bubble tea.png" alt="Oreo Boba" />
                        </div>
                        <div class="home-card-body">
                            <span class="home-card-cat">Bubble Tea</span>
                            <p class="home-card-nombre">Oreo Boba</p>
                            <p class="home-card-precio">₡3,000</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="home-carrusel-dots" id="brew-dots"></div>
    </div>

    <div class="home-divider" style="margin-top:2.5rem;"><hr /></div>

    @* Sección Bubble Tea *@
    <div class="section-divider">
    </div>
    <div class="home-divider">
        <div class="home-section-header">
            <h2 class="home-section-titulo">Bubble Tea</h2>
            <span class="home-section-tag">Nuestras estrellas</span>
        </div>

        <div class="home-grid">

            <div class="home-card">
                <div class="home-card-stripe"></div>
                <div class="home-card-img-wrap">
                    <img src="~/images/productos/Bubble Tea Original_BubbleTea.png" alt="Bubble Tea Original" />
                </div>
                <div class="home-card-body">
                    <span class="home-card-cat">Bubble Tea</span>
                    <p class="home-card-nombre">Original Bubble Tea</p>
                    <p class="home-card-precio">₡2,500</p>
                </div>
            </div>

            <div class="home-card">
                <div class="home-card-stripe"></div>
                <div class="home-card-img-wrap">
                    <img src="~/images/productos/Bubble Tea Matcha_BubbleTea.png" alt="Matcha Bubble Tea" />
                </div>
                <div class="home-card-body">
                    <span class="home-card-cat">Bubble Tea</span>
                    <p class="home-card-nombre">Matcha Bubble Tea</p>
                    <p class="home-card-precio">₡2,800</p>
                </div>
            </div>

            <div class="home-card">
                <div class="home-card-stripe"></div>
                <div class="home-card-img-wrap">
                    <img src="~/images/productos/Bubble Tea Taro_BubbleTea.png" alt="Taro Bubble Tea" />
                </div>
                <div class="home-card-body">
                    <span class="home-card-cat">Bubble Tea</span>
                    <p class="home-card-nombre">Taro Bubble Tea</p>
                    <p class="home-card-precio">₡2,800</p>
                </div>
            </div>

            <div class="home-card">
                <div class="home-card-stripe"></div>
                <div class="home-card-img-wrap">
                    <img src="~/images/productos/OreoBoba_Bubble tea.png" alt="Oreo Boba" />
                </div>
                <div class="home-card-body">
                    <span class="home-card-cat">Bubble Tea</span>
                    <p class="home-card-nombre">Oreo Boba</p>
                    <p class="home-card-precio">₡3,000</p>
                </div>
            </div>

            <div class="home-card">
                <div class="home-card-stripe"></div>
                <div class="home-card-img-wrap">
                    <img src="~/images/productos/CoffeeBoba _Bubble tea.png" alt="Coffee Boba" />
                </div>
                <div class="home-card-body">
                    <span class="home-card-cat">Bubble Tea</span>
                    <p class="home-card-nombre">Coffee Boba</p>
                    <p class="home-card-precio">₡3,000</p>
                </div>
            </div>

        </div>
    </div>

    <div class="section-divider"><hr /></div>

    @* Sección Café *@
    <div class="home-section cafes">
        <div class="home-section-header">
            <h2 class="home-section-titulo">Cafés</h2>
            <span class="home-section-tag">Especialidad</span>
        </div>

        <div class="home-grid">

            <div class="home-card">
                <div class="home-card-stripe"></div>
                <div class="home-card-img-wrap">
                    <img src="~/images/productos/IcedAmericano_Café.png" alt="Iced Americano" />
                </div>
                <div class="home-card-body">
                    <span class="home-card-cat">Café</span>
                    <p class="home-card-nombre">Iced Americano</p>
                    <p class="home-card-precio">₡2,200</p>
                </div>
            </div>

            <div class="home-card">
                <div class="home-card-stripe"></div>
                <div class="home-card-img-wrap">
                    <img src="~/images/productos/IcedLatte_Café.png" alt="Iced Latte" />
                </div>
                <div class="home-card-body">
                    <span class="home-card-cat">Café</span>
                    <p class="home-card-nombre">Iced Latte</p>
                    <p class="home-card-precio">₡2,500</p>
                </div>
            </div>

            <div class="home-card">
                <div class="home-card-stripe"></div>
                <div class="home-card-img-wrap">
                    <img src="~/images/productos/IcedMocha_Café.png" alt="Iced Mocha" />
                </div>
                <div class="home-card-body">
                    <span class="home-card-cat">Café</span>
                    <p class="home-card-nombre">Iced Mocha</p>
                    <p class="home-card-precio">₡2,700</p>
                </div>
            </div>

        </div>
    </div>

</div>



