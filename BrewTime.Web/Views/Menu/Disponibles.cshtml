@model IEnumerable<BrewTime.Application.DTOs.MenuDTO>

@{
    ViewData["Title"] = "Menús Disponibles";
}

<h1 class="text-center mb-4">Menús Disponibles</h1>

<p class="text-center">
    Esta pantalla muestra únicamente los menús que se encuentran disponibles según su fecha, hora y día configurado.
</p>

@foreach (var menu in Model)
{
    <div class="card mb-5 shadow">
        <div class="card-header bg-dark text-white text-center">
            <h2>@menu.Nombre</h2>
            <p>@menu.Descripcion</p>
        </div>

        <div class="card-body">
            <div class="mb-4 text-center">
                <strong>Horario:</strong> @menu.HoraInicio - @menu.HoraFin <br />
                <strong>Fechas:</strong> @menu.FechaInicio - @menu.FechaFin
            </div>

            <hr />

            <h3 class="text-center">Productos</h3>

            @if (menu.MenuProducto != null && menu.MenuProducto.Any())
            {
                var productosAgrupados = menu.MenuProducto
                .GroupBy(x => x.Producto.CategoriaNombre);

                foreach (var grupo in productosAgrupados)
                {
                    <h4 class="mt-4 border-bottom pb-2">@grupo.Key</h4>

                    <div class="row">
                        @foreach (var item in grupo)
                        {
                            <div class="col-md-4 mb-3">
                                <div class="card h-100">
                                    <div class="card-body">
                                        <h5>@item.Producto.Nombre</h5>
                                        <p>@item.Producto.Descripcion</p>
                                        <strong>₡@item.Producto.Precio</strong>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <p>No hay productos disponibles.</p>
            }

            <hr />

            <h3 class="text-center">Combos</h3>

            @if (menu.MenuCombo != null && menu.MenuCombo.Any())
            {
                var combosAgrupados = menu.MenuCombo
                .GroupBy(x => x.Combo.CategoriaNombre);

                foreach (var grupo in combosAgrupados)
                {
                    <h4 class="mt-4 border-bottom pb-2">@grupo.Key</h4>

                    <div class="row">
                        @foreach (var item in grupo)
                        {
                            <div class="col-md-4 mb-3">
                                <div class="card h-100 border-success">
                                    <div class="card-body">
                                        <h5>@item.Combo.Nombre</h5>
                                        <p>@item.Combo.Descripcion</p>
                                        <strong>₡@item.Combo.PrecioEspecial</strong>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <p>No hay combos disponibles.</p>
            }
        </div>
    </div>
}
