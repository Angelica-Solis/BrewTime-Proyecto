@model IEnumerable<BrewTime.Application.DTOs.MenuDTO>

@section Styles {
    <link rel="stylesheet" href="~/css/Menu.css" asp-append-version="true" />
}

@{
    ViewData["Title"] = "Listado de Menús";
}

<div class="menu-page">

    <div class="menu-hero">
        <div class="menu-hero-inner">
            <p class="menu-eyebrow">Brew Time · Cafetería</p>
            <h1 class="menu-title">Listado de <em>Menús</em></h1>
            <p class="menu-subtitle">
                Administración de menús registrados en el sistema.
            </p>
        </div>
    </div>

    <div class="menu-content">

        <p>
            Esta pantalla muestra todos los menús registrados en el sistema,
            ordenados desde el más reciente hasta el más antiguo.
        </p>

        <div class="menu-card">
            <div class="menu-card-header">
                Menús registrados
            </div>

            <div class="menu-card-body">
                <table class="menu-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th>Hora Inicio</th>
                            <th>Hora Fin</th>
                            <th>Fecha Creación</th>
                            <th>Estado</th>
                            <th>Acción</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Nombre</td>
                                <td>@item.Descripcion</td>
                                <td>@item.HoraInicio</td>
                                <td>@item.HoraFin</td>
                                <td>@item.FechaCreacion.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.Activo)
                                    {
                                        <span class="menu-badge-active">Disponible</span>
                                    }
                                    else
                                    {
                                        <span class="menu-badge-inactive">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Detail"
                                       asp-route-id="@item.MenuId"
                                       class="menu-btn">
                                        Detalle
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>