@model IEnumerable<BrewTime.Application.DTOs.MenuDTO>

@section Styles {
    <link rel="stylesheet" href="~/css/Menu.css" asp-append-version="true" />
}

@{
    ViewData["Title"] = "Listado de Menús";

    var menus = Model
        .OrderByDescending(x => x.Activo)
        .ThenByDescending(x => x.FechaInicio)
        .ThenByDescending(x => x.FechaCreacion)
        .ToList();
}

<div class="menu-page">

    <div class="menu-hero">
        <div class="menu-hero-inner">
            <p class="menu-eyebrow">Brew Time · Cafetería</p>
            <h1 class="menu-title">Listado de <em>Menús</em></h1>
            <p class="menu-subtitle">
                Consulta general de todos los menús registrados en el sistema.
            </p>
        </div>
    </div>

    <div class="menu-content">

        <p>
            Esta pantalla lista todos los menús registrados, mostrando información relevante
            para identificarlos y ordenados desde el menú disponible más reciente.
        </p>

        @if (!menus.Any())
        {
            <div class="menu-card">
                <div class="menu-card-body">
                    <p class="menu-empty">No hay menús registrados.</p>
                </div>
            </div>
        }
        else
        {
            <div class="menu-card">
                <div class="menu-card-header">
                    Listado de menús
                </div>

                <div class="menu-card-body">
                    <table class="menu-table">
                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Horario</th>
                                <th>Fechas</th>
                                <th>Estado</th>
                                <th>Acción</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in menus)
                            {
                                <tr>
                                    <td>
                                        <strong>@item.Nombre</strong><br />
                                        <small>@item.Descripcion</small>
                                    </td>

                                    <td>
                                        @item.HoraInicio.ToString("HH:mm") -
                                        @item.HoraFin.ToString("HH:mm")
                                    </td>

                                    <td>
                                        @if (item.FechaInicio != null && item.FechaFin != null)
                                        {
                                            <span>
                                                @item.FechaInicio.Value.ToString("dd/MM/yyyy")
                                                -
                                                @item.FechaFin.Value.ToString("dd/MM/yyyy")
                                            </span>
                                        }
                                        else
                                        {
                                            <span>No definido</span>
                                        }
                                    </td>

                                    <td>
                                        @if (item.Activo)
                                        {
                                            <span class="menu-badge-active">Disponible</span>
                                        }
                                        else
                                        {
                                            <span class="menu-badge-inactive">Inactivo</span>
                                        }
                                    </td>

                                    <td>
                                        <a asp-action="Detail"
                                           asp-route-id="@item.MenuId"
                                           class="menu-btn">
                                            Detalle
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

    </div>
</div>