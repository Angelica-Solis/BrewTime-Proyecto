@model IEnumerable<BrewTime.Application.DTOs.MenuDTO>

@section Styles {
    <link rel="stylesheet" href="~/css/Menu.css" asp-append-version="true" />
}

@{
    ViewData["Title"] = "Listado de Menús";

    var menus = Model
        .OrderByDescending(x => x.FechaInicio)
        .ThenByDescending(x => x.HoraInicio)
        .ThenByDescending(x => x.FechaCreacion)
        .ToList();
}

<div class="menu-page">

    <div class="menu-hero">
        <div class="menu-hero-inner">
            <p class="menu-eyebrow">Brew Time · Administración</p>
            <h1 class="menu-title">Listado de <em>Menús</em></h1>
            <p class="menu-subtitle">
                Consulta general de los menús registrados.
            </p>
        </div>
    </div>

    <div class="menu-content">

        @if (!menus.Any())
        {
            <div class="menu-detail-card">
                <div class="menu-detail-body">
                    <p class="menu-empty">No hay menús registrados.</p>
                </div>
            </div>
        }
        else
        {
            <p class="menu-count-text">
                @menus.Count menú(s) registrado(s)
            </p>

            <div class="menu-table-card menu-index-card">

                <div class="menu-index-header">
                    <div>
                        <p class="menu-index-label">Menús registrados</p>
                        <h2>Listado general</h2>
                    </div>
                </div>

                <table class="menu-table menu-index-table">
                    <thead>
                        <tr>
                            <th>Menú</th>
                            <th>Horario</th>
                            <th>Disponibilidad</th>
                            <th>Estado</th>
                            <th>Acción</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in menus)
                        {
                            <tr>
                                <td>
                                    <span class="menu-table-title">@item.Nombre</span>

                                    @if (!string.IsNullOrWhiteSpace(item.Descripcion))
                                    {
                                        <span class="menu-small-text">@item.Descripcion</span>
                                    }
                                    else
                                    {
                                        <span class="menu-small-text">Sin descripción registrada</span>
                                    }
                                </td>

                                <td>
                                    <span class="menu-table-main">
                                        @item.HoraInicio.ToString("HH:mm") - @item.HoraFin.ToString("HH:mm")
                                    </span>
                                </td>

                                <td>
                                    @if (item.FechaInicio != null && item.FechaFin != null)
                                    {
                                        <span class="menu-table-main">
                                            @item.FechaInicio.Value.ToString("dd/MM/yyyy")
                                        </span>
                                        <span class="menu-small-text">
                                            hasta @item.FechaFin.Value.ToString("dd/MM/yyyy")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="menu-small-text">No definido</span>
                                    }
                                </td>

                                <td>
                                    @if (item.Activo)
                                    {
                                        <span class="menu-badge-active">Disponible</span>
                                    }
                                    else
                                    {
                                        <span class="menu-badge-inactive">Inactivo</span>
                                    }
                                </td>

                                <td>
                                    <a asp-action="Detail"
                                       asp-route-id="@item.MenuId"
                                       class="menu-btn">
                                        Detalle
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>