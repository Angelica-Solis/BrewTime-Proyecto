@model BrewTime.Application.DTOs.MenuDTO

@section Styles {
    <link rel="stylesheet" href="~/css/Menu.css" asp-append-version="true" />
}

@{
    ViewData["Title"] = "Detalle del Menú";
}

<div class="menu-page">

    <div class="menu-hero">
        <div class="menu-hero-inner">
            <p class="menu-eyebrow">Brew Time · Cafetería</p>
            <h1 class="menu-title">Detalle del <em>Menú</em></h1>
            <p class="menu-subtitle">
                Información completa del menú seleccionado.
            </p>
        </div>
    </div>

    <div class="menu-content">

        <div class="menu-card">
            <div class="menu-card-header">
                Información general del menú
            </div>

            <div class="menu-card-body">
                <h4 class="menu-name">@Model.Nombre</h4>

                <p>
                    <strong>Descripción:</strong>
                    @Model.Descripcion
                </p>

                <p>
                    <strong>Horario:</strong>
                    @Model.HoraInicio - @Model.HoraFin
                </p>

                <p>
                    <strong>Fechas:</strong>
                    @Model.FechaInicio - @Model.FechaFin
                </p>

                <p>
                    <strong>Estado:</strong>
                    @if (Model.Activo)
                    {
                        <span class="menu-badge-active">Activo</span>
                    }
                    else
                    {
                        <span class="menu-badge-inactive">Inactivo</span>
                    }
                </p>
            </div>
        </div>

        <div class="menu-card">
            <div class="menu-card-header">
                Días disponibles
            </div>

            <div class="menu-card-body">
                @if (Model.MenuDiaSemana != null && Model.MenuDiaSemana.Any())
                {
                    <ul>
                        @foreach (var dia in Model.MenuDiaSemana)
                        {
                            <li>Día: @dia.DiaSemana</li>
                        }
                    </ul>
                }
                else
                {
                    <p class="menu-empty">No hay días registrados para este menú.</p>
                }
            </div>
        </div>

        <div class="menu-card">
            <div class="menu-card-header">
                Productos del menú
            </div>

            <div class="menu-card-body">
                @if (Model.MenuProducto != null && Model.MenuProducto.Any())
                {
                    <table class="menu-table">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th>Descripción</th>
                                <th>Precio</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model.MenuProducto)
                            {
                                <tr>
                                    <td>@item.Producto.Nombre</td>
                                    <td>@item.Producto.Descripcion</td>
                                    <td>₡@item.Producto.Precio</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="menu-empty">No hay productos registrados para este menú.</p>
                }
            </div>
        </div>

        <div class="menu-card">
            <div class="menu-card-header">
                Combos del menú
            </div>

            <div class="menu-card-body">
                @if (Model.MenuCombo != null && Model.MenuCombo.Any())
                {
                    <table class="menu-table">
                        <thead>
                            <tr>
                                <th>Combo</th>
                                <th>Descripción</th>
                                <th>Precio Especial</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model.MenuCombo)
                            {
                                <tr>
                                    <td>@item.Combo.Nombre</td>
                                    <td>@item.Combo.Descripcion</td>
                                    <td>₡@item.Combo.PrecioEspecial</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="menu-empty">No hay combos registrados para este menú.</p>
                }
            </div>
        </div>

        <a asp-action="Index" class="menu-btn-secondary">
            ← Volver
        </a>

    </div>
