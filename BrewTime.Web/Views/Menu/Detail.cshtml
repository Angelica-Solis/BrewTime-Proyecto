@model BrewTime.Application.DTOs.MenuDTO

@section Styles {
    <link rel="stylesheet" href="~/css/Menu.css" asp-append-version="true" />
}

@{
    ViewData["Title"] = "Detalle del Menú";

    string NombreDia(byte dia)
    {
        return dia switch
        {
            1 => "Lunes",
            2 => "Martes",
            3 => "Miércoles",
            4 => "Jueves",
            5 => "Viernes",
            6 => "Sábado",
            7 => "Domingo",
            _ => "Día no definido"
        };
    }
}

<div class="menu-page">

    <div class="menu-hero">
        <div class="menu-hero-inner">
            <p class="menu-eyebrow">Brew Time · Cafetería</p>
            <h1 class="menu-title">Detalle del <em>Menú</em></h1>
            <p class="menu-subtitle">
                Información completa del menú seleccionado.
            </p>
        </div>
    </div>

    <div class="menu-content">

        <a asp-action="Index" class="menu-btn-secondary">
            ← Volver al listado
        </a>

        <div class="menu-detail-card">
            <div class="menu-detail-body">

                <h2 class="menu-detail-title menu-detail-main-title">
                    @Model.Nombre
                </h2>

                <p class="menu-lead">
                    @Model.Descripcion
                </p>

                <div class="menu-info-grid">

                    <div class="menu-info-item">
                        <span class="menu-info-label">Horario</span>
                        <span class="menu-info-value">
                            @Model.HoraInicio.ToString("HH:mm") - @Model.HoraFin.ToString("HH:mm")
                        </span>
                    </div>

                    <div class="menu-info-item">
                        <span class="menu-info-label">Fechas</span>
                        <span class="menu-info-value">
                            @if (Model.FechaInicio != null && Model.FechaFin != null)
                            {
                                <span>
                                    @Model.FechaInicio.Value.ToString("dd/MM/yyyy")
                                    -
                                    @Model.FechaFin.Value.ToString("dd/MM/yyyy")
                                </span>
                            }
                            else
                            {
                                <span>No definido</span>
                            }
                        </span>
                    </div>

                    <div class="menu-info-item">
                        <span class="menu-info-label">Estado</span>
                        <span class="menu-info-value">
                            @if (Model.Activo)
                            {
                                <span class="menu-badge-active">Activo</span>
                            }
                            else
                            {
                                <span class="menu-badge-inactive">Inactivo</span>
                            }
                        </span>
                    </div>

                </div>

                <h2 class="menu-detail-title">
                    Días <em>disponibles</em>
                </h2>

                @if (Model.MenuDiaSemana != null && Model.MenuDiaSemana.Any())
                {
                    <div class="menu-days-list">
                        @foreach (var dia in Model.MenuDiaSemana.OrderBy(x => x.DiaSemana))
                        {
                            <span class="menu-day-chip">@NombreDia(dia.DiaSemana)</span>
                        }
                    </div>
                }
                else
                {
                    <p class="menu-empty">No hay días registrados para este menú.</p>
                }

            </div>
        </div>

        <h2 class="menu-detail-title">
            Productos del <em>menú</em>
        </h2>

        @if (Model.MenuProducto != null && Model.MenuProducto.Any())
        {
            <div class="menu-table-wrapper">
                <table class="menu-table">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Categoría</th>
                            <th>Precio</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.MenuProducto)
                        {
                            <tr>
                                <td>
                                    <span class="menu-table-title">
                                        @item.Producto.Nombre
                                    </span>
                                </td>

                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.Producto.CategoriaNombre))
                                    {
                                        <span class="menu-category-chip">
                                            @item.Producto.CategoriaNombre
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="menu-category-chip menu-category-chip-empty">
                                            Sin categoría
                                        </span>
                                    }
                                </td>

                                <td>
                                    <span class="menu-price-text">
                                        ₡@item.Producto.Precio.ToString("N2")
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="menu-detail-card">
                <div class="menu-detail-body">
                    <p class="menu-empty">No hay productos registrados para este menú.</p>
                </div>
            </div>
        }

        <h2 class="menu-detail-title">
            Combos del <em>menú</em>
        </h2>

        @if (Model.MenuCombo != null && Model.MenuCombo.Any())
        {
            <div class="menu-table-wrapper">
                <table class="menu-table">
                    <thead>
                        <tr>
                            <th>Combo</th>
                            <th>Categoría</th>
                            <th>Precio especial</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.MenuCombo)
                        {
                            <tr>
                                <td>
                                    <span class="menu-table-title">
                                        @item.Combo.Nombre
                                    </span>
                                </td>

                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.Combo.CategoriaNombre))
                                    {
                                        <span class="menu-category-chip">
                                            @item.Combo.CategoriaNombre
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="menu-category-chip menu-category-chip-empty">
                                            Sin categoría
                                        </span>
                                    }
                                </td>

                                <td>
                                    <span class="menu-price-text">
                                        ₡@item.Combo.PrecioEspecial.ToString("N2")
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="menu-detail-card">
                <div class="menu-detail-body">
                    <p class="menu-empty">No hay combos registrados para este menú.</p>
                </div>
            </div>
        }

    </div>
</div>